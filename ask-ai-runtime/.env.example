ASK_AI_API_KEY=replace-with-strong-random-key
ASK_AI_PROVIDER=openai
ASK_AI_MODEL=gpt-4.1-mini
ASK_AI_BASE_URL=https://api.openai.com/v1
ASK_AI_PROVIDER_API_KEY=replace-with-provider-key
# Optional shared provider key fallback (recommended for centralized entitlement model)
DOCSOPS_SHARED_OPENAI_API_KEY=
ASK_AI_REQUIRE_AUTH=true
ASK_AI_BILLING_MODE=user-subscription
ASK_AI_WEBHOOK_SECRET=replace-with-webhook-secret
ASK_AI_MAX_CONTEXT_MODULES=6
ASK_AI_MAX_TOKENS=700
ASK_AI_TEMPERATURE=0.2
ASK_AI_RATE_LIMIT_PER_USER_PER_MINUTE=20
ASK_AI_KNOWLEDGE_INDEX_PATH=docs/assets/knowledge-retrieval-index.json
ASK_AI_ASSISTANT_BUNDLE_GLOB=reports/intent-bundles/*-assistant.json
