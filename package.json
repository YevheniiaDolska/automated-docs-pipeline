{
  "name": "auto-doc-pipeline",
  "version": "1.0.0",
  "description": "Automated documentation pipeline with GEO optimization",
  "scripts": {
    "prepare": "husky install",
    "lint": "npm run normalize:docs:check && npm run lint:vale && npm run lint:md && npm run lint:spell && npm run lint:frontmatter && npm run lint:geo && npm run lint:knowledge && npm run lint:snippets && npm run lint:multilang",
    "normalize:docs": "python3 scripts/normalize_docs.py docs/",
    "normalize:docs:check": "python3 scripts/normalize_docs.py docs/ --check",
    "lint:vale": "vale docs/",
    "lint:md": "markdownlint docs/",
    "lint:spell": "cspell \"docs/**/*.md\" --no-must-find-files",
    "lint:frontmatter": "python3 scripts/validate_frontmatter.py",
    "lint:geo": "python3 scripts/seo_geo_optimizer.py docs/",
    "lint:knowledge": "python3 scripts/validate_knowledge_modules.py",
    "glossary:sync": "python3 scripts/sync_project_glossary.py --paths docs --glossary glossary.yml --report reports/glossary_sync_report.json --write",
    "lint:snippets": "python3 scripts/lint_code_snippets.py docs/ --strict",
    "lint:snippets:strict": "python3 scripts/lint_code_snippets.py docs/ templates/ --strict",
    "lint:multilang": "python3 scripts/validate_multilang_examples.py --docs-dir docs --scope api --required-languages curl,javascript,python",
    "lint:multilang:all": "python3 scripts/validate_multilang_examples.py --docs-dir docs --scope all --required-languages curl,javascript,python",
    "generate:multilang-tabs": "python3 scripts/generate_multilang_tabs.py --paths docs templates --scope api --write",
    "generate:multilang-tabs:all": "python3 scripts/generate_multilang_tabs.py --paths docs templates --scope all --write",
    "lint:diagrams": "python3 scripts/validate_diagram_content.py docs templates --strict",
    "lint:examples-smoke": "python3 scripts/check_code_examples_smoke.py --paths docs templates",
    "lint:examples-smoke:network": "python3 scripts/check_code_examples_smoke.py --paths docs templates --allow-network",
    "validate:minimal": "npm run normalize:docs:check && npm run lint:md && npm run lint:frontmatter && npm run lint:geo && npm run lint:multilang && npm run lint:examples-smoke",
    "lint:layers": "python3 scripts/doc_layers_validator.py --strict",
    "validate:full": "npm run validate:minimal && npm run lint:layers && npm run lint:diagrams && npm run validate:knowledge && npm run docs-ops:e2e && npm run docs-ops:golden && npm run docs-ops:test-suite && python3 test_pipeline.py",
    "serve": "python3 scripts/run_generator.py serve",
    "serve:mkdocs": "mkdocs serve",
    "serve:docusaurus": "npx docusaurus start",
    "agent:claude:auto": "bash scripts/claude-auto.sh",
    "demo:claude:loop": "bash scripts/claude-demo-loop.sh",
    "demo:api-first": "bash scripts/api_first_demo_live.sh",
    "demo:api-first:stop": "bash scripts/api_first_demo_stop.sh",
    "api-first-demo": "bash scripts/api_first_demo_live.sh",
    "api-first-demo:stop": "bash scripts/api_first_demo_stop.sh",
    "agent:codex:auto": "bash scripts/codex-auto.sh",
    "demo:codex": "bash scripts/codex-demo.sh",
    "demo:codex:loop": "bash scripts/codex-demo-loop.sh",
    "build": "python3 scripts/run_generator.py build",
    "build:mkdocs": "mkdocs build --strict",
    "build:docusaurus": "npx docusaurus build",
    "convert:to-docusaurus": "python3 scripts/markdown_converter.py to-docusaurus docs/",
    "convert:to-mkdocs": "python3 scripts/markdown_converter.py to-mkdocs docs/",
    "generator:detect": "python3 scripts/run_generator.py detect",
    "generator:info": "python3 scripts/run_generator.py info",
    "build:intent": "python3 scripts/assemble_intent_experience.py",
    "build:knowledge-index": "python3 scripts/generate_knowledge_retrieval_index.py",
    "build:knowledge-enrich:llm": "python3 scripts/enrich_knowledge_modules_semantic.py",
    "build:knowledge-graph": "python3 scripts/generate_knowledge_graph_jsonld.py --modules-dir knowledge_modules --output docs/assets/knowledge-graph.jsonld --report reports/knowledge_graph_report.json",
    "build:rag:reindex": "python3 scripts/rag_reindex_lifecycle.py --repo-root . --with-embeddings --provider local",
    "build:intent:all": "python3 scripts/build_all_intent_experiences.py",
    "eval:retrieval": "python3 scripts/run_retrieval_evals_gate.py",
    "validate:knowledge": "npm run lint:knowledge && npm run build:intent:all && npm run build:knowledge-index && npm run build:knowledge-graph && npm run eval:retrieval",
    "validate:knowledge:with-llm-enrich": "npm run build:knowledge-enrich:llm && npm run validate:knowledge",
    "configurator": "python3 scripts/generate_configurator.py",
    "onboard:client": "python3 scripts/onboard_client.py",
    "bundle:free-enterprise": "python3 scripts/build_free_enterprise_bundle.py --client profiles/clients/acme.client.yml",
    "askai:status": "python3 scripts/configure_ask_ai.py --status",
    "askai:enable": "python3 scripts/configure_ask_ai.py --enable",
    "askai:disable": "python3 scripts/configure_ask_ai.py --disable",
    "askai:configure": "python3 scripts/configure_ask_ai.py",
    "askai:runtime:install": "python3 scripts/install_ask_ai_runtime.py --target-dir .",
    "askai:runtime:install:force": "python3 scripts/install_ask_ai_runtime.py --target-dir . --force",
    "gaps": "python3 -m scripts.gap_detection.cli analyze",
    "gaps:full": "python3 -m scripts.gap_detection.cli full --generate",
    "gaps:community": "python3 -m scripts.gap_detection.cli community",
    "gaps:code": "python3 -m scripts.gap_detection.cli code",
    "gaps:generate": "python3 -m scripts.gap_detection.cli generate --report reports/doc_gaps_report.json",
    "new-doc": "python3 scripts/new_doc.py",
    "kpi-wall": "python3 scripts/generate_kpi_wall.py --docs-dir docs --reports-dir reports --stale-days 90",
    "badges": "python3 scripts/generate_badge.py --json reports/kpi-wall.json --output reports",
    "kpi-full": "npm run kpi-wall && npm run badges",
    "release-pack": "python3 scripts/generate_release_docs_pack.py --output reports/release-docs-pack.md",
    "docs-contract": "python3 scripts/check_docs_contract.py --base origin/main --head HEAD --json-output reports/pr_docs_contract.json",
    "drift-check": "python3 scripts/check_api_sdk_drift.py --base origin/main --head HEAD --json-output reports/api_sdk_drift_report.json --md-output reports/api_sdk_drift_report.md",
    "kpi-sla": "python3 scripts/evaluate_kpi_sla.py --current reports/kpi-wall.json --policy-pack policy_packs/api-first.yml --json-output reports/kpi-sla-report.json --md-output reports/kpi-sla-report.md",
    "audit:scorecard": "python3 scripts/generate_audit_scorecard.py --docs-dir docs --reports-dir reports --spec-path api/openapi.yaml --policy-pack policy_packs/api-first.yml --glossary-path glossary.yml --stale-days 180 --auto-run-smoke --json-output reports/audit_scorecard.json --html-output reports/audit_scorecard.html",
    "audit:public": "python3 scripts/generate_public_docs_audit.py",
    "audit:public:wizard": "python3 scripts/generate_public_docs_audit.py --interactive",
    "audit:public:llm": "python3 scripts/generate_public_docs_audit.py --llm-enabled --llm-model claude-sonnet-4-5 --llm-api-key-env-name ANTHROPIC_API_KEY",
    "audit:public:llm-summary": "python3 scripts/generate_public_docs_audit.py --llm-enabled --llm-summary-only --llm-model claude-sonnet-4-5 --llm-api-key-env-name ANTHROPIC_API_KEY",
    "audit:executive-pdf": "python3 scripts/generate_executive_audit_pdf.py --scorecard-json reports/audit_scorecard.json --public-audit-json reports/public_docs_audit.json --llm-summary-json reports/public_docs_audit_llm_summary.json --company-name \"Client\"",
    "api:sandbox:mock": "docker compose -f docker-compose.api-sandbox.yml up -d",
    "api:sandbox:stop": "docker compose -f docker-compose.api-sandbox.yml down",
    "api:sandbox:project": "bash scripts/api_sandbox_project.sh",
    "api:sandbox:prodlike": "bash scripts/api_prodlike_project.sh",
    "api:sandbox:prodlike:up": "bash scripts/api_prodlike_project.sh up taskstream 4011",
    "api:sandbox:prodlike:down": "bash scripts/api_prodlike_project.sh down taskstream 4011",
    "api:sandbox:prodlike:status": "bash scripts/api_prodlike_project.sh status taskstream 4011",
    "api:sandbox:prodlike:logs": "bash scripts/api_prodlike_project.sh logs taskstream 4011",
    "api:sandbox:live": "bash scripts/api_sandbox_live.sh up taskstream ./api/openapi.yaml 4010",
    "api:sandbox:live:stop": "bash scripts/api_sandbox_live.sh down taskstream ./api/openapi.yaml 4010",
    "api:sandbox:live:status": "bash scripts/api_sandbox_live.sh status taskstream ./api/openapi.yaml 4010",
    "api:sandbox:live:logs": "bash scripts/api_sandbox_live.sh logs taskstream ./api/openapi.yaml 4010",
    "lint:openapi": "npx -y @stoplight/spectral-cli lint api/openapi.yaml --ruleset .spectral.yml && npx -y @redocly/cli lint api/openapi.yaml && npx -y @apidevtools/swagger-cli validate api/openapi.yaml && python3 scripts/validate_openapi_contract.py api/openapi.yaml",
    "api:test:assets": "python3 scripts/generate_api_test_assets.py --spec api/openapi.yaml --output-dir reports/api-test-assets --testrail-csv reports/api-test-assets/testrail_test_cases.csv --zephyr-json reports/api-test-assets/zephyr_test_cases.json",
    "api:test:upload": "python3 scripts/upload_api_test_assets.py --cases-json reports/api-test-assets/api_test_cases.json --report reports/api-test-assets/upload_report.json",
    "openapi:overrides": "python3 scripts/apply_openapi_overrides.py --spec api/openapi.yaml --spec-tree api/taskstream --overrides api/overrides/openapi.manual.yml",
    "openapi:regression": "python3 scripts/check_openapi_regression.py --spec api/openapi.yaml --spec-tree api/taskstream --snapshot api/.openapi-regression.json",
    "openapi:regression:update": "python3 scripts/check_openapi_regression.py --spec api/openapi.yaml --spec-tree api/taskstream --snapshot api/.openapi-regression.json --update",
    "api:first:flow:taskstream": "python3 scripts/run_api_first_flow.py --project-slug taskstream --notes demos/api-first/taskstream-planning-notes.md --spec api/openapi.yaml --spec-tree api/taskstream --docs-provider mkdocs --inject-demo-nav --auto-remediate",
    "api:first:v0:taskstream": "python3 scripts/run_api_first_flow.py --project-slug taskstream --notes demos/api-first/taskstream-planning-notes.md --spec api/openapi.yaml --spec-tree api/taskstream --docs-provider mkdocs --auto-remediate --max-attempts 3",
    "api-first:demo": "bash -lc 'set -e; bash scripts/api_sandbox_project.sh up taskstream ./api/openapi.yaml 4010; trap \"bash scripts/api_sandbox_project.sh down taskstream ./api/openapi.yaml 4010\" EXIT; python3 scripts/run_api_first_flow.py --project-slug taskstream --notes demos/api-first/taskstream-planning-notes.md --spec api/openapi.yaml --spec-tree api/taskstream --docs-provider mkdocs --inject-demo-nav --verify-user-path --mock-base-url http://localhost:4010/v1 --auto-remediate --max-attempts 3'",
    "api-first:demo:live": "bash scripts/api_first_demo_live.sh",
    "api-first:demo:stop": "bash scripts/api_first_demo_stop.sh",
    "api:first:verify-user-path": "python3 scripts/self_verify_api_user_path.py --base-url http://localhost:4010/v1",
    "api:first:verify-user-path:prodlike": "python3 scripts/self_verify_prodlike_user_path.py --base-url http://localhost:4011/v1",
    "docs-ops:e2e": "python3 scripts/test_docs_ops_e2e.py",
    "docs-ops:golden": "python3 scripts/test_golden_reports_and_workflows.py",
    "docs-ops:test-suite": "python3 -m pytest -q tests/test_autopipeline_suite.py",
    "test:all": "python3 -m pytest -q tests",
    "test:adapter": "python3 -m pytest tests/test_docusaurus_adapter.py -v",
    "test:configurator": "python3 -m pytest tests/test_gui_configurator.py -v",
    "i18n:sync": "python3 scripts/i18n_sync.py",
    "i18n:translate": "python3 scripts/i18n_translate.py",
    "i18n:translate:all": "python3 scripts/i18n_translate.py --all-missing",
    "i18n:translate:stale": "python3 scripts/i18n_translate.py --stale-only",
    "i18n:migrate": "python3 scripts/i18n_migrate.py",
    "confluence:migrate": "python3 scripts/run_confluence_migration.py",
    "doc:compile": "python3 scripts/compile_doc_overview.py --docs-dir docs --reports-dir reports --modalities all",
    "consolidate": "npm run gaps && npm run kpi-wall && npm run kpi-sla && npm run i18n:sync && npm run validate:knowledge && python3 scripts/consolidate_reports.py",
    "consolidate:reports-only": "python3 scripts/consolidate_reports.py",
    "docsops:generate": "python3 scripts/docsops_generate.py generate --mode operator --trigger always",
    "docsops:generate:auto": "python3 scripts/docsops_generate.py generate --mode operator --trigger always --auto",
    "docsops:generate:policy": "python3 scripts/docsops_generate.py generate --mode operator --trigger policy --auto",
    "docsops:generate:veridoc": "python3 scripts/docsops_generate.py generate --mode veridoc --trigger policy --auto",
    "smoke:prod": "python3 scripts/production_smoke.py"
  },
  "devDependencies": {
    "husky": "^8.0.3",
    "markdownlint-cli": "^0.38.0",
    "cspell": "^8.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
