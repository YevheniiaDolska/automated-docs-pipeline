# VeriDoc Production Environment Variables
# Copy to .env and fill in all required values

# ---- Database ----
POSTGRES_USER=veridoc
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=veridoc
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- API Server ----
API_PORT=8000
WEB_PORT=3000
VERIDOC_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
VERIDOC_CORS_ORIGINS=https://app.veri-doc.app,https://veri-doc.app
VERIDOC_ENVIRONMENT=production
VERIOPS_LICENSE_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
VERIDOC_LICENSE_AUTORENEW_ENABLED=true
VERIDOC_LICENSE_STORE_DIR=/var/lib/veridoc/licenses

# ---- LLM API Keys ----
# At least one is required for Phase 2 doc generation
GROQ_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- LemonSqueezy Billing ----
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Variant IDs (from LemonSqueezy dashboard)
LS_VARIANT_STARTER_MONTHLY=
LS_VARIANT_STARTER_ANNUAL=
LS_VARIANT_PRO_MONTHLY=
LS_VARIANT_PRO_ANNUAL=
LS_VARIANT_BUSINESS_MONTHLY=
LS_VARIANT_BUSINESS_ANNUAL=
LS_VARIANT_ENTERPRISE_MONTHLY=
LS_VARIANT_ENTERPRISE_ANNUAL=

# ---- SMTP (email notifications) ----
VERIDOC_SMTP_HOST=smtp.mailgun.org
VERIDOC_SMTP_PORT=587
VERIDOC_SMTP_USER=
VERIDOC_SMTP_PASSWORD=
VERIDOC_SMTP_FROM=noreply@veri-doc.app
VERIDOC_APP_BASE_URL=https://veri-doc.app
VERIDOC_ADMIN_EMAIL=jane.dolska@gmail.com,eugenia@veri-doc.app

# ---- Sentry error tracking ----
SENTRY_DSN=

# ---- Production smoke test account ----
VERIDOC_BASE_URL=https://api.veri-doc.app
VERIDOC_SMOKE_EMAIL=smoke@veri-doc.app
VERIDOC_SMOKE_PASSWORD=CHANGE_ME_STRONG

# ---- Domain (choose one setup) ----
# Option A: Subdomains (recommended)
#   DNS: api.veri-doc.app, app.veri-doc.app, docs.veri-doc.app
#   All pointing to your server IP
#
# Option B: Path-based
#   DNS: veri-doc.app pointing to your server IP
#   Edit nginx.conf to use Option B block
