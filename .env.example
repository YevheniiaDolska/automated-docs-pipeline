# Auto-Doc Pipeline local environment template
# Copy to `.env` (or `.env.local` / `.env.docsops.local`).
# Entrypoint scripts now auto-load these files if present.

# --- Test asset upload toggles ---
TESTRAIL_UPLOAD_ENABLED=false
ZEPHYR_UPLOAD_ENABLED=false

# --- TestRail ---
TESTRAIL_BASE_URL=https://your-company.testrail.io
TESTRAIL_EMAIL=qa-owner@company.com
TESTRAIL_API_KEY=replace-with-testrail-api-key
TESTRAIL_SECTION_ID=123
# Optional:
TESTRAIL_SUITE_ID=

# --- Zephyr Scale ---
# Optional, defaults to SmartBear cloud API if empty:
ZEPHYR_SCALE_BASE_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_SCALE_API_TOKEN=replace-with-zephyr-token
ZEPHYR_SCALE_PROJECT_KEY=PROJ
# Optional:
ZEPHYR_SCALE_FOLDER_ID=

# --- Optional external mock (Postman) ---
POSTMAN_API_KEY=
POSTMAN_WORKSPACE_ID=
POSTMAN_COLLECTION_UID=
POSTMAN_MOCK_SERVER_ID=
