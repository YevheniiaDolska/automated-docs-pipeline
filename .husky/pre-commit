#!/bin/sh
# Pre-commit hook: runs ALL documentation quality checks and shows ALL errors at once.
# Collects failures from every linter, then blocks the commit if any failed.
# Install: npx husky install && npx husky add .husky/pre-commit "sh .husky/pre-commit"

echo "Running documentation quality checks..."

# Get list of staged .md files (exclude non-doc paths: .claude/, .codex/, root reports)
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' | grep -v -E '^(\.claude/|\.codex/|instructions/|lifecycle-report\.md|README\.md|AGENTS\.md|CLAUDE\.md|README_SETUP\.md|FULL_IMPLEMENTATION_START_HERE\.md|PILOT_START_HERE\.md|PILOT_VS_FULL_IMPLEMENTATION\.md|PILOT_WEEK_OFFER\.md|PRICING_CHEATSHEET_RU\.md|OPERATOR_QUESTIONNAIRE\.md|UPSELL_SALES_PLAYBOOK\.md|SETUP_FOR_PROJECTS\.md|CLIENT_HANDOFF\.md|PRODUCT_STRATEGY\.md|templates/legal/)' || true)

# Get list of staged API spec files (OpenAPI/Swagger)
STAGED_API=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(openapi|swagger|api-spec).*\.(yaml|yml|json)$' | grep -v '\.bundled\.' || true)

if [ -z "$STAGED_MD" ] && [ -z "$STAGED_API" ]; then
    echo "No Markdown or API spec files staged. Skipping checks."
    exit 0
fi

if [ -n "$STAGED_MD" ]; then
    echo "Checking markdown files: $STAGED_MD"
fi
if [ -n "$STAGED_API" ]; then
    echo "Checking API spec files: $STAGED_API"
fi

# Split staged files into English and non-English for locale-aware linting.
# Vale and cspell run only on English docs; markdownlint and frontmatter run on all.
STAGED_EN=$(echo "$STAGED_MD" | grep -v -E '^docs/(ru|de|fr|es|zh|ja|ko|pt)/' || true)
STAGED_NON_EN=$(echo "$STAGED_MD" | grep -E '^docs/(ru|de|fr|es|zh|ja|ko|pt)/' || true)

# Track failures across all checks
FAILED=""

# POSIX-safe command detection helper (/bin/sh compatible)
have_cmd() {
    command -v "$1" >/dev/null 2>&1
}

# Check that command exists and is runnable in current shell context.
can_run_cmd() {
    have_cmd "$1" && "$1" --version >/dev/null 2>&1
}

# Resolve Python interpreter once (prefer python3)
PYTHON_BIN=""
if have_cmd python3; then
    PYTHON_BIN="python3"
elif have_cmd python; then
    PYTHON_BIN="python"
fi

# Resolve Vale binary once (support WSL + Windows-installed vale.exe)
VALE_BIN=""
if can_run_cmd vale; then
    VALE_BIN="vale"
elif can_run_cmd vale.exe; then
    VALE_BIN="vale.exe"
fi

# Auto-normalize staged markdown before checks (single source of formatting truth)
if [ -n "$STAGED_MD" ] && [ -n "$PYTHON_BIN" ] && [ -f "scripts/normalize_docs.py" ]; then
    echo ""
    echo "0a/7 Normalizing staged markdown..."
    "$PYTHON_BIN" scripts/normalize_docs.py $STAGED_MD
    if [ $? -ne 0 ]; then
        FAILED="$FAILED normalize-docs"
    else
        # Re-stage normalized files so commit includes canonical formatting.
        git add $STAGED_MD
    fi
fi

# 0. API contract lint stack (API specs) - runs first, independent of Markdown
echo ""
echo "0/7 API contract lint stack..."
if [ -n "$STAGED_API" ]; then
    for file in $STAGED_API; do
        echo "  Validating: $file"

        if have_cmd spectral; then
            spectral lint "$file" --ruleset .spectral.yml
        else
            npx -y @stoplight/spectral-cli lint "$file" --ruleset .spectral.yml
        fi
        if [ $? -ne 0 ]; then
            FAILED="$FAILED spectral"
        fi

        if have_cmd redocly; then
            redocly lint "$file"
        else
            npx -y @redocly/cli lint "$file"
        fi
        if [ $? -ne 0 ]; then
            FAILED="$FAILED redocly"
        fi

        if have_cmd swagger-cli; then
            swagger-cli validate "$file"
        else
            npx -y @apidevtools/swagger-cli validate "$file"
        fi
        if [ $? -ne 0 ]; then
            FAILED="$FAILED swagger-cli"
        fi

        if [ -n "$PYTHON_BIN" ] && [ -f "scripts/validate_openapi_contract.py" ]; then
            "$PYTHON_BIN" scripts/validate_openapi_contract.py "$file"
            if [ $? -ne 0 ]; then
                FAILED="$FAILED api-contract"
            fi
        fi
    done
else
    echo "No API spec files staged. Skipping."
fi

# 1. Vale (style check)
echo ""
echo "1/7 Vale (style)..."
if [ -n "$STAGED_MD" ] && [ -n "$VALE_BIN" ]; then
    # Vale runs on all files but .vale.ini applies GEO-only rules
    # for non-English locales automatically via glob overrides.
    "$VALE_BIN" $STAGED_MD
    if [ $? -ne 0 ]; then
        FAILED="$FAILED vale"
    fi
elif [ -z "$STAGED_MD" ]; then
    echo "No Markdown files staged. Skipping style check."
else
    echo "Vale not installed. Skipping style check."
fi

# 2. markdownlint (formatting)
echo ""
echo "2/7 markdownlint (formatting)..."
if [ -n "$STAGED_MD" ] && have_cmd markdownlint; then
    markdownlint $STAGED_MD
    if [ $? -ne 0 ]; then
        FAILED="$FAILED markdownlint"
    fi
elif [ -z "$STAGED_MD" ]; then
    echo "No Markdown files staged. Skipping markdownlint."
else
    echo "markdownlint not installed. Skipping."
fi

# 3. cspell (spelling) -- English docs only
echo ""
echo "3/7 cspell (spelling)..."
if [ -n "$STAGED_MD" ] && have_cmd cspell; then
    if [ -n "$STAGED_EN" ]; then
        cspell --no-progress $STAGED_EN
        if [ $? -ne 0 ]; then
            FAILED="$FAILED cspell"
        fi
    else
        echo "No English docs staged. Skipping spell check."
    fi
    if [ -n "$STAGED_NON_EN" ]; then
        echo "  (Skipped spell check for non-English: $STAGED_NON_EN)"
    fi
elif [ -z "$STAGED_MD" ]; then
    echo "No Markdown files staged. Skipping spell check."
else
    echo "cspell not installed. Skipping."
fi

# 4. Frontmatter validation
echo ""
echo "4/7 Frontmatter validation..."
if [ -n "$STAGED_MD" ] && [ -f "scripts/validate_frontmatter.py" ]; then
    if [ -n "$PYTHON_BIN" ]; then
        "$PYTHON_BIN" scripts/validate_frontmatter.py
        if [ $? -ne 0 ]; then
            FAILED="$FAILED frontmatter"
        fi
    else
        echo "python/python3 not found. Skipping frontmatter validation."
    fi
elif [ -z "$STAGED_MD" ]; then
    echo "No Markdown files staged. Skipping frontmatter validation."
else
    echo "validate_frontmatter.py not found. Skipping."
fi

# 5. SEO/GEO optimization
echo ""
echo "5/7 SEO/GEO optimization..."
if [ -n "$STAGED_MD" ] && [ -f "scripts/seo_geo_optimizer.py" ]; then
    if [ -n "$PYTHON_BIN" ]; then
        for file in $STAGED_MD; do
            "$PYTHON_BIN" scripts/seo_geo_optimizer.py "$file"
            if [ $? -ne 0 ]; then
                FAILED="$FAILED seo-geo"
            fi
        done
    else
        echo "python/python3 not found. Skipping SEO/GEO optimization."
    fi
elif [ -z "$STAGED_MD" ]; then
    echo "No Markdown files staged. Skipping SEO/GEO optimization."
else
    echo "seo_geo_optimizer.py not found. Skipping."
fi

# 6. Knowledge modules validation
echo ""
echo "6/7 Knowledge modules validation..."
if [ -f "scripts/validate_knowledge_modules.py" ]; then
    if [ -n "$PYTHON_BIN" ]; then
        "$PYTHON_BIN" scripts/validate_knowledge_modules.py
        if [ $? -ne 0 ]; then
            FAILED="$FAILED knowledge"
        fi
    else
        echo "python/python3 not found. Skipping knowledge validation."
    fi
else
    echo "validate_knowledge_modules.py not found. Skipping."
fi

# Final verdict
echo ""
if [ -n "$FAILED" ]; then
    echo "============================================"
    echo "  COMMIT BLOCKED: quality checks failed"
    echo "============================================"
    echo "  Failed checks:$FAILED"
    echo "  Fix all issues above, then commit again."
    echo "============================================"
    exit 1
fi

echo "All checks passed!"
exit 0
