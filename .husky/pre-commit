#!/bin/sh
# Pre-commit hook: runs ALL documentation quality checks and shows ALL errors at once.
# Collects failures from every linter, then blocks the commit if any failed.
# Install: npx husky install && npx husky add .husky/pre-commit "sh .husky/pre-commit"

echo "Running documentation quality checks..."

# Get list of staged .md files
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

# Get list of staged API spec files (OpenAPI/Swagger)
STAGED_API=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(openapi|swagger|api-spec).*\.(yaml|yml|json)$' || true)

if [ -z "$STAGED_MD" ]; then
    echo "No Markdown files staged. Skipping checks."
    exit 0
fi

echo "Checking files: $STAGED_MD"

# Split staged files into English and non-English for locale-aware linting.
# Vale and cspell run only on English docs; markdownlint and frontmatter run on all.
STAGED_EN=$(echo "$STAGED_MD" | grep -v -E '^docs/(ru|de|fr|es|zh|ja|ko|pt)/' || true)
STAGED_NON_EN=$(echo "$STAGED_MD" | grep -E '^docs/(ru|de|fr|es|zh|ja|ko|pt)/' || true)

# Track failures across all checks
FAILED=""

# 0. Spectral (API specs) - runs first, independent of Markdown
echo ""
echo "0/6 Spectral (API specs)..."
if [ -n "$STAGED_API" ]; then
    if command -v spectral &> /dev/null; then
        for file in $STAGED_API; do
            echo "  Validating: $file"
            spectral lint "$file" --ruleset .spectral.yml
            if [ $? -ne 0 ]; then
                FAILED="$FAILED spectral"
            fi
        done
    else
        echo "Spectral not installed. Install: npm install -g @stoplight/spectral-cli"
    fi
else
    echo "No API spec files staged. Skipping."
fi

# 1. Vale (style check)
echo ""
echo "1/6 Vale (style)..."
if command -v vale &> /dev/null; then
    # Vale runs on all files but .vale.ini applies GEO-only rules
    # for non-English locales automatically via glob overrides.
    vale $STAGED_MD
    if [ $? -ne 0 ]; then
        FAILED="$FAILED vale"
    fi
else
    echo "Vale not installed. Skipping style check."
fi

# 2. markdownlint (formatting)
echo ""
echo "2/6 markdownlint (formatting)..."
if command -v markdownlint &> /dev/null; then
    markdownlint $STAGED_MD
    if [ $? -ne 0 ]; then
        FAILED="$FAILED markdownlint"
    fi
else
    echo "markdownlint not installed. Skipping."
fi

# 3. cspell (spelling) -- English docs only
echo ""
echo "3/6 cspell (spelling)..."
if command -v cspell &> /dev/null; then
    if [ -n "$STAGED_EN" ]; then
        cspell --no-progress $STAGED_EN
        if [ $? -ne 0 ]; then
            FAILED="$FAILED cspell"
        fi
    else
        echo "No English docs staged. Skipping spell check."
    fi
    if [ -n "$STAGED_NON_EN" ]; then
        echo "  (Skipped spell check for non-English: $STAGED_NON_EN)"
    fi
else
    echo "cspell not installed. Skipping."
fi

# 4. Frontmatter validation
echo ""
echo "4/6 Frontmatter validation..."
if [ -f "scripts/validate_frontmatter.py" ]; then
    python scripts/validate_frontmatter.py
    if [ $? -ne 0 ]; then
        FAILED="$FAILED frontmatter"
    fi
else
    echo "validate_frontmatter.py not found. Skipping."
fi

# 5. GEO lint
echo ""
echo "5/6 GEO optimization..."
if [ -f "scripts/geo_lint.py" ]; then
    for file in $STAGED_MD; do
        python scripts/geo_lint.py "$file"
        if [ $? -ne 0 ]; then
            FAILED="$FAILED geo-lint"
        fi
    done
else
    echo "geo_lint.py not found. Skipping."
fi

# Final verdict
echo ""
if [ -n "$FAILED" ]; then
    echo "============================================"
    echo "  COMMIT BLOCKED: quality checks failed"
    echo "============================================"
    echo "  Failed checks:$FAILED"
    echo "  Fix all issues above, then commit again."
    echo "============================================"
    exit 1
fi

echo "All checks passed!"
exit 0
