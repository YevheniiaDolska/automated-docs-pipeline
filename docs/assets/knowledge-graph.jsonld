      "@id": "urn:module:webhook-auth-baseline",
      "@type": "KnowledgeModule",
      "name": "Configure HMAC authentication for inbound webhooks",
      "description": "Covers secure webhook authentication setup for docs, assistant responses, in-product hints, and automation workflows with one reusable module.",
      "status": "active",
      "priority": 95,
      "intents": [
